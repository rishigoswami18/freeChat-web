{
  "name": "antigravity-avatar",
  "displayName": "AntiGravity AI Avatar Assistant",
  "description": "Real-time talking AI avatar assistant in VS Code",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Education"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity.startAssistant",
        "title": "Start AntiGravity Assistant"
      }
    ],
    "configuration": {
      "title": "AntiGravity Avatar",
      "properties": {
        "antigravity.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for Gemini Model (Google AI Studio)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "axios": "^1.6.5"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "typescript": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0"
  }
}
